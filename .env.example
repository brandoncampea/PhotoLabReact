# Local development environment variables
# Copy this file to .env.local and update with your values

# Common ASP.NET ports: 5000 (HTTP), 5001 (HTTPS), 7000-7100 (HTTPS)
# Use http:// for local development without SSL
VITE_API_URL=http://localhost:5000/api

# Azure Blob Storage base URL for images/assets
VITE_AZURE_BLOB_BASE_URL=https://campeaphotolab.blob.core.windows.net/photos
