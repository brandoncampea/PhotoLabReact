# Local development environment variables
# Copy this file to .env.local and update with your values

# Common ASP.NET ports: 5000 (HTTP), 5001 (HTTPS), 7000-7100 (HTTPS)
# Use http:// for local development without SSL
VITE_API_URL=http://localhost:5000/api

# Azure Blob Storage base URL for images/assets
VITE_AZURE_BLOB_BASE_URL=https://campeaphotolab.blob.core.windows.net/photos

# WHCC Lab API credentials
WHCC_CONSUMER_KEY=your_whcc_consumer_key
WHCC_CONSUMER_SECRET=your_whcc_consumer_secret
WHCC_SANDBOX=false
# Webhook callback URL — must be publicly reachable by WHCC
# In production set this to your deployed domain, e.g.:
# WHCC_WEBHOOK_URL=https://your-prod-domain.com/api/webhooks/whcc
WHCC_WEBHOOK_URL=https://your-prod-domain.com/api/webhooks/whcc

# Meta / Instagram Graph API (app-wide, not per-studio)
# Studio-specific access tokens and IG/Page IDs should be stored in DB by studio_id.
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=http://localhost:3000/api/instagram/connect/callback
META_GRAPH_VERSION=v20.0
INSTAGRAM_MAX_CAROUSEL_ITEMS=20
INSTAGRAM_OAUTH_STATE_SECRET=replace_with_long_random_value
INSTAGRAM_OAUTH_STATE_TTL_MINUTES=15
SOCIAL_TOKEN_ENCRYPTION_KEY=replace_with_32_byte_base64_or_strong_passphrase
