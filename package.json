{
  "name": "photolabreact",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/server.mjs",
    "server.mjs": "node server/server.mjs",
    "start": "node server/server.mjs",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "build": "tsc && vite build",
    "build:appservice": "vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "seed:photos": "node server/seedPhotos.js",
    "seed:products": "node server/seedProducts.js",
    "seed:test-commerce": "node server/seedTestCommerce.js",
    "normalize:test-commerce": "node server/normalizeTestCommerce.js",
    "clear:test-commerce": "node server/clearTestCommerce.js --apply",
    "clear:test-commerce:dry-run": "node server/clearTestCommerce.js",
    "migrate:sqlite": "node server/migrateSqliteToMssql.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "deploy:azure:appservice": "./scripts/deploy-azure-appservice.sh"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.0.1",
    "@tensorflow-models/blazeface": "^0.1.0",
    "@tensorflow/tfjs": "^4.22.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/papaparse": "^5.5.2",
    "axios": "^1.6.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "chart.js": "^4.5.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "cropperjs": "^1.6.1",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.3.1",
    "exif-reader": "^2.0.3",
    "exifr": "^7.1.3",
    "express": "^5.2.1",
    "face-api.js": "^0.20.0",
    "jsonwebtoken": "^9.0.3",
    "mssql": "^11.0.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.2",
    "papaparse": "^5.5.3",
    "react": "18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-cropper": "^2.3.3",
    "react-dom": "18.3.1",
    "react-router-dom": "^6.21.0",
    "sharp": "^0.34.5",
    "stripe": "^20.3.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^7.3.1"
  }
}
