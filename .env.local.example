# Azure SQL / MSSQL Configuration
# Preferred: use the same connection string as GitHub Secret MSSQL_CONNECTION_STRING
MSSQL_CONNECTION_STRING=Server=tcp:YOUR_SERVER.database.windows.net,1433;Initial Catalog=YOUR_DB;Persist Security Info=False;User ID=YOUR_USER;Password=YOUR_PASSWORD;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# Alternative (if you don't use MSSQL_CONNECTION_STRING)
DB_HOST=YOUR_SERVER.database.windows.net
DB_PORT=1433
DB_NAME=YOUR_DB
DB_USER=YOUR_USER
DB_PASSWORD=YOUR_PASSWORD
MSSQL_ENCRYPT=true
MSSQL_TRUST_CERT=false

# JWT Secret (change in production!)
JWT_SECRET=cTAO5EOgFHpjiW3Pwqdn10x22PbVbKr0On6StkS8P6I=

# Admin Email Override (comma-separated list)
ADMIN_EMAILS=admin@photolab.com

# Stripe (required for seed:test-commerce)
STRIPE_SECRET_KEY=sk_test_your_key_here

# SMTP — order receipt emails
# Leave SMTP_HOST empty to disable email sending (receipts skipped silently)
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_SECURE=false
SMTP_FROM=Photo Lab <no-reply@yourdomain.com>
SMTP_REPLY_TO=support@yourdomain.com

# Base URL of the deployed app (used to build order links in studio receipts)
# Example: https://yourapp.azurewebsites.net
APP_BASE_URL=https://your-app-url.azurewebsites.net

# Vite Configuration
VITE_USE_MOCK_API=false
