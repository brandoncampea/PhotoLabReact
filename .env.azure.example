# Azure App Service deployment environment variables
# Copy to .env.azure and fill values, then source it before running deploy script.

AZURE_WEBAPP_NAME=CampeaPhotoLab
AZURE_RESOURCE_GROUP=PhotoLab

# Required
JWT_SECRET=replace-with-strong-random-secret

# Preferred DB option (use this OR DB_* below)
# MSSQL_CONNECTION_STRING=Server=tcp:<server>.database.windows.net,1433;Initial Catalog=<db>;Persist Security Info=False;User ID=<user>;Password=<password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# DB option 2 (if not using MSSQL_CONNECTION_STRING)
DB_HOST=
DB_PORT=1433
DB_NAME=
DB_USER=
DB_PASSWORD=
MSSQL_ENCRYPT=true
MSSQL_TRUST_CERT=false

# Optional integrations
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MPIX_API_KEY=
MPIX_API_SECRET=

# Azure Blob Storage (required for album photo uploads)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=photos

# Optional override (defaults to your App Service URL)
# FRONTEND_URL=https://CampeaPhotoLab.azurewebsites.net

# Build-time API URL (defaults to /api)
# VITE_API_URL=/api
